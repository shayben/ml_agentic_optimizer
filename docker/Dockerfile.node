FROM pytorch/pytorch:2.4.1-cuda12.1-cudnn9-runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    CONTROL_PLANE_RUN_ID=default

WORKDIR /workspace
COPY . /workspace

RUN python -m pip install --upgrade pip \
    && python -m pip install ".[torch,gpu,mlflow]"

# Dev Tunnels CLI — required only for the node-hosted "submit-then-attach" topology
# (examples/selfhost_and_train.py / examples/aml_job_selfhost.yml). Harmless for the default
# agent-hosted topology. Remove this layer if your build environment cannot reach aka.ms.
RUN (command -v curl >/dev/null 2>&1 || (apt-get update \
        && apt-get install -y --no-install-recommends curl \
        && rm -rf /var/lib/apt/lists/*)) \
    && curl -sL https://aka.ms/DevTunnelCliInstall | bash

# Copilot CLI is intentionally not installed here; it runs locally with MCP stdio.
# The training script reads CONTROL_PLANE_URL, CONTROL_PLANE_TOKEN, and CONTROL_PLANE_RUN_ID.
CMD ["bash", "-lc", "python examples/train_with_bridge.py --broker ${CONTROL_PLANE_URL:?set CONTROL_PLANE_URL}"]
